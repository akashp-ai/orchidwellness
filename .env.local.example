# ─────────────────────────────────────────────
# Orchid Wellness — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.

# ── Email config (for the Inquiry Widget) ────
# Without these, inquiries are only saved to data/inquiries.txt (local only).
# For Vercel or hosted deployments, configure these so you receive email notifications.

# Gmail example (use an App Password, not your real Gmail password):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# The email address where inquiries will be sent:
CONTACT_EMAIL=owner@orchidwellness.in
